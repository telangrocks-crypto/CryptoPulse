<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".CryptoPulseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CryptoPulse"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- Main Activity -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Registration Activity -->
        <activity
            android:name=".ui.auth.RegistrationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Login Activity -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Dashboard Activity -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- API Key Activity -->
        <activity
            android:name=".ui.apikey.ApiKeyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Strategy Selection Activity -->
        <activity
            android:name=".ui.strategy.StrategySelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- OTP Activity -->
        <activity
            android:name=".ui.auth.OtpActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Change Mobile Activity -->
        <activity
            android:name=".ui.auth.ChangeMobileActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Subscription Activity -->
        <activity
            android:name=".ui.subscription.SubscriptionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Splash Activity -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Trade History Activity -->
        <activity
            android:name=".ui.history.TradeHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Order History Activity -->
        <activity
            android:name=".ui.history.OrderHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Disable Default WorkManager Initializer to use Hilt Worker Factory -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
