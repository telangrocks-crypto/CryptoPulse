<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:gravity="center">

        <!-- Futuristic Logo / Branding -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/app_logo_hero"
            android:contentDescription="App Logo"
            android:scaleType="fitCenter"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <TextView
            style="@style/TextAppearance.CryptoPulse.HeadLine1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textAlignment="center"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <TextView
            style="@style/TextAppearance.CryptoPulse.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please enter your email address and password"
            android:textAlignment="center"
            android:layout_marginBottom="@dimen/spacing_2xl" />

        <!-- Input Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_balance_border"
            android:padding="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:hint="Email Address"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="@color/status_success">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    style="@style/Widget.CryptoPulse.EditText" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:hint="Password"
                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="@color/status_success"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    style="@style/Widget.CryptoPulse.EditText" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                style="@style/Widget.CryptoPulse.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="LOGIN"
                app:backgroundTint="@color/status_success" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRegister"
            style="@style/TextAppearance.CryptoPulse.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Register Now"
            android:textAlignment="center"
            android:textColor="@color/status_success"
            android:textStyle="bold"
            android:padding="@dimen/spacing_xs" />

        <TextView
            style="@style/TextAppearance.CryptoPulse.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By logging in, you agree to our Terms of Service and Privacy Policy"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/spacing_lg" />

    </LinearLayout>

</ScrollView>