<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_screen"
    tools:context=".ui.splash.SplashActivity">

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shrikant Telang"
        android:textSize="@dimen/text_28sp"
        android:textStyle="bold"
        android:textColor="@color/brand_primary"
        android:layout_marginBottom="42dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CryptoPulse"
        android:textSize="@dimen/text_36sp"
        android:textStyle="bold"
        android:textColor="@color/brand_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI-Powered Trading Platform"
        android:textSize="@dimen/text_14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_primary" />

</LinearLayout>