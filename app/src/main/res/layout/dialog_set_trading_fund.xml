<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardBackgroundColor="@color/bg_card"
    app:cardElevation="8dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/status_success"
    app:cardCornerRadius="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header: Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Balance"
                style="@style/TextAppearance.CryptoPulse.Body"
                android:fontFamily="sans-serif-black"
                android:shadowColor="@color/brand_primary"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="15"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_16sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"/>
                
            <TextView
                android:id="@+id/tvWalletBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                style="@style/TextAppearance.CryptoPulse.HeadLine1"
                android:fontFamily="sans-serif-black"
                android:shadowColor="@color/brand_primary"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="20"
                android:textSize="@dimen/text_36sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
        
        <!-- Input Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENTRY PRICE (USDT)"
                style="@style/TextAppearance.CryptoPulse.BodySmall"
                android:textColor="@color/status_success"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>
                
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeColor="@color/status_success"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_26sp"
                        android:fontFamily="sans-serif-black" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInvestment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:inputType="numberDecimal"
                        android:hint="10"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_26sp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:padding="0dp"
                        android:layout_marginStart="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SPECIFIC ENTRY PRICE (COIN VALUE)"
                style="@style/TextAppearance.CryptoPulse.BodySmall"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>
                
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp"
                app:strokeColor="@color/text_secondary"
                app:strokeWidth="1dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEntryPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:inputType="numberDecimal"
                        android:hint="Current Market"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_20sp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:padding="0dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- Stop Loss (Left) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="start">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STOP LOSS"
                        android:textSize="@dimen/text_11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvStopLossDynamic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$0.00"
                        android:textSize="@dimen/text_16sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_error" />
                </LinearLayout>

                <!-- Center Probability -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WIN FREQUENCY"
                        android:textSize="@dimen/text_11sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary" />
                    <TextView
                        android:id="@+id/tvWinProbability"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textSize="@dimen/text_20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <!-- Take Profit (Right) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TAKE PROFIT"
                        android:textSize="@dimen/text_11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvTakeProfitDynamic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+$0.00"
                        android:textSize="@dimen/text_16sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_success" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The bot dynamically structures actual coin prices for Stop Loss and Take Profit behind the scenes based on this capital entry."
                style="@style/TextAppearance.CryptoPulse.BodySmall"
                android:textColor="@color/status_info"
                android:gravity="center" 
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:lineSpacingExtra="2dp"
                android:textSize="@dimen/text_11sp"/>

        </LinearLayout>

        <!-- Validation Error Message -->
        <TextView
            android:id="@+id/tvValidationError"
            style="@style/TextAppearance.CryptoPulse.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_error"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            style="@style/Widget.CryptoPulse.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE"
            app:backgroundTint="@color/status_success"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
