<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Column 1: Symbol -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSymbol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTC/USDT"
                style="@style/TextAppearance.CryptoPulse.Body"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_primary" />
            
        </LinearLayout>

        <!-- Column 2: Price -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="43,250.00"
                style="@style/TextAppearance.CryptoPulse.Body"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                android:textColor="@color/status_warning"
                android:gravity="end" />

            <TextView
                android:id="@+id/tvChange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+0.00%"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Column 3: Signal -->
        <TextView
            android:id="@+id/tvSignal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="BUY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
    <!-- Analysis Dashboard Panel (Attached Dynamically) -->
    <FrameLayout
        android:id="@+id/layoutAnalysisContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>